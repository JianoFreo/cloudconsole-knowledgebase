PORT=5000
NODE_ENV=development

# Neon Postgres connection string (the pooled one from Neon's Connect page
# works fine here - @neondatabase/serverless talks to it over HTTP, not a
# persistent TCP connection, so there's no separate "direct" URL needed).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Only needed if the frontend is deployed separately from this backend.
# Not needed in the normal monolithic setup (this server serves the built
# frontend itself).
CLIENT_ORIGIN="*"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
